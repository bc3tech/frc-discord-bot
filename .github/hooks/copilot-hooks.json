{
  "hooks": {
    "sessionEnd": [
      {
        "bash": "node .github/hooks/scripts/observe.js sessionEnd 2\u003e/dev/null || true",
        "powershell": "try { node .github/hooks/scripts/observe.js sessionEnd 2\u003e$null } catch {}",
        "timeoutSec": 10,
        "type": "command"
      }
    ],
    "sessionStart": [
      {
        "bash": "node .github/hooks/scripts/observe.js sessionStart 2\u003e/dev/null || true",
        "powershell": "try { node .github/hooks/scripts/observe.js sessionStart 2\u003e$null } catch {}",
        "timeoutSec": 5,
        "type": "command"
      }
    ]
  },
  "version": 1
}
