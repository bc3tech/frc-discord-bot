{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "discordToken": {
        "value": "${Discord__Token}"
      },
      "firstPassword": {
        "value": "${FIRST__Password}"
      },
      "tbaApiKey": {
        "value": "${TbaApiKey}"
      },
      "chatBotAgentId": {
        "value": "${AI__Azure__AgentId=}"
      },
      "chatBotAgent365Enabled": {
        "value": "${AI__Agent365__Enabled=}"
      },
      "chatBotAgent365TenantId": {
        "value": "${AI__Agent365__TenantId=}"
      },
      "chatBotAgent365BlueprintClientId": {
        "value": "${AI__Agent365__BlueprintClientId=}"
      },
      "chatBotAgent365ManagedIdentityClientId": {
        "value": "${AI__Agent365__ManagedIdentityClientId=}"
      },
      "chatBotAgent365AgentIdentityClientId": {
        "value": "${AI__Agent365__AgentIdentityClientId=}"
      },
      "chatBotAgent365AutoCreateIdentity": {
        "value": "${AI__Agent365__AutoCreateIdentity=}"
      },
      "chatBotAgent365AgentIdentityDisplayName": {
        "value": "${AI__Agent365__AgentIdentityDisplayName=}"
      },
      "chatBotAgent365Sponsors": {
        "value": "${AI__Agent365__Sponsors=}"
      },
      "chatBotAgent365TokenExchangeAudience": {
        "value": "${AI__Agent365__TokenExchangeAudience=}"
      },
      "chatBotAgent365ProbeScope": {
        "value": "${AI__Agent365__ProbeScope=}"
      },
      "searchServiceName": {
        "value": "${SEARCH_SERVICE_NAME=}"
      },
      "searchLocation": {
        "value": "${SEARCH_LOCATION=${FOUNDRY_LOCATION=${AZURE_LOCATION}}}"
      },
      "appExists": {
        "value": "${SERVICE_APP_RESOURCE_EXISTS=false}"
      },
      "foundryLocation": {
        "value": "${FOUNDRY_LOCATION=${AZURE_LOCATION}}"
      }
    }
}
