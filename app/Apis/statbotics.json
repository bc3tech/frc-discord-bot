    "/v3/teams": {
      "get": {
        "tags": [
          "Team"
        ],
        "summary": "Query multiple teams",
        "description": "Returns up to 1000 teams at a time. Specify limit and offset to page through results.",
        "operationId": "list_teams",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "description": "Capitalized country name, for example USA or Canada.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "description": "Capitalized two-letter state code, for example NC.",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            }
          },
          {
            "name": "district",
            "in": "query",
            "required": false,
            "description": "District code.",
            "schema": {
              "type": "string",
              "enum": [
                "ca",
                "fch",
                "fim",
                "fin",
                "fit",
                "fma",
                "fnc",
                "fsc",
                "isr",
                "ne",
                "ont",
                "pch",
                "pnw",
                "win"
              ]
            }
          },
          {
            "name": "active",
            "in": "query",
            "required": false,
            "description": "Whether the team has played in the last year.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "metric",
            "in": "query",
            "required": false,
            "description": "How to sort the returned values. Any column in the table is valid.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ascending",
            "in": "query",
            "required": false,
            "description": "Whether to sort the returned values in ascending order. Default is ascending.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of records to return. Default is 1000.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Offset from the first result to return.",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObjectArray"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
