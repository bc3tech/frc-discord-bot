{
  "openapi": "3.0.3",
  "info": {
    "title": "Statbotics REST API",
    "description": "The REST API for Statbotics. Please be nice to their servers. This version is normalized for Azure Foundry OpenAPI tool ingestion.",
    "version": "3.0.0"
  },
  "servers": [
    {
      "url": "https://api.statbotics.io",
      "description": "Statbotics production API"
    }
  ],
  "paths": {
    "/v3/": {
      "get": {
        "tags": [
          "Default"
        ],
        "summary": "Read Root",
        "description": "Returns the API root payload for version 3.",
        "operationId": "get_root",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        }
      }
    },
    "/v3/year/{year}": {
      "get": {
        "tags": [
          "Year"
        ],
        "summary": "Query a single year",
        "description": "Returns a single Year object. Requires a four-digit year, for example 2019.",
        "operationId": "get_year",
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "description": "Four-digit year.",
            "schema": {
              "type": "integer",
              "minimum": 2002,
              "maximum": 2026
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v3/years": {
      "get": {
        "tags": [
          "Year"
        ],
        "summary": "Query multiple years",
        "operationId": "list_years",
        "parameters": [
          {
            "name": "metric",
            "in": "query",
            "required": false,
            "description": "How to sort the returned values. Any column in the table is valid.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ascending",
            "in": "query",
            "required": false,
            "description": "Whether to sort the returned values in ascending order. Default is ascending.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of records to return. Default is 1000.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Offset from the first result to return.",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns a list of years since 2002.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObjectArray"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
