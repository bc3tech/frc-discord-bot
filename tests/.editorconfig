# Test projects: silence all dotnet style/quality analyzers.
# Test code prioritizes clarity and intent over strict conventions, and
# generated test stubs (e.g., openapi-generator) trigger a lot of noise.
#
# This file does NOT set `root = true` so settings still inherit from the
# repo-root .editorconfig (indentation, line endings, etc.). Only analyzer
# severities are overridden.

[*.{cs,vb}]
# Blanket-silence every analyzer category. Anything not matched above is
# caught by these category-level rules.
dotnet_analyzer_diagnostic.category-Style.severity = none

# CA1816: Dispose methods should call SuppressFinalize
dotnet_diagnostic.CA1816.severity = none

# Default severity for analyzer diagnostics with category 'Naming'
dotnet_analyzer_diagnostic.category-Naming.severity = none
